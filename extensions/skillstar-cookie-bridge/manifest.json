{
  "manifest_version": 3,
  "name": "SkillStar Cookie Bridge",
  "version": "0.1.0",
  "description": "Import OpenCode console cookies into local SkillStar.",
  "permissions": ["cookies", "activeTab", "storage", "tabs"],
  "host_permissions": ["https://opencode.ai/*", "https://console.opencode.ai/*", "http://127.0.0.1:1461/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "SkillStar Cookie Bridge"
  }
}
