# Antigravity (Google IDE) OAuth — required for Usage → Antigravity login / quota refresh.
# Obtain from the Antigravity IDE install or copy into ~/.skillstar/config/antigravity_oauth.json:
#   { "client_id": "...", "client_secret": "..." }
SKILLSTAR_ANTIGRAVITY_CLIENT_ID=
SKILLSTAR_ANTIGRAVITY_CLIENT_SECRET=