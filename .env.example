# Antigravity (Google IDE) OAuth — required for Usage → Antigravity login / quota refresh.
# Obtain from the Antigravity IDE install or copy into ~/.skillstar/config/antigravity_oauth.json:
#   { "client_id": "...", "client_secret": "..." }
SKILLSTAR_ANTIGRAVITY_CLIENT_ID=
SKILLSTAR_ANTIGRAVITY_CLIENT_SECRET=

# Optional OAuth client overrides for Usage providers. Each ships a working
# built-in default, so leave these blank unless a built-in client gets rotated
# or you register your own. Resolution order per value:
#   env var → compile-time option_env! → ~/.skillstar/config/oauth_clients.json → built-in default
# The JSON file shape is:
#   { "codex": { "client_id": "..." }, "trae": { "client_id": "...", "client_secret": "..." }, ... }
SKILLSTAR_CODEX_CLIENT_ID=
SKILLSTAR_XAI_CLIENT_ID=
SKILLSTAR_TRAE_CLIENT_ID=
SKILLSTAR_TRAE_CLIENT_SECRET=
SKILLSTAR_OPENCODE_CLIENT_ID=