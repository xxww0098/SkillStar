{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    {
      "identifier": "shell:allow-execute",
      "allow": []
    },
    "shell:allow-open",
    "dialog:default",
    "deep-link:default",
    "updater:default",
    "process:default"
  ]
}
