{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SkillStar",
  "version": "0.1.3",
  "identifier": "com.skillstar.desktop",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SkillStar",
        "hiddenTitle": true,
        "width": 1400,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://api.github.com https://github.com; img-src 'self' https://avatars.githubusercontent.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU1Qjg1NjgyRkVCNDhCRDYKUldUV2k3VCtnbGE0NVNxS05SS3dqazA4S2xzNkN1WnZFY1VnS0JWQm1kRk1nM05WWkl6em9qaWUK",
      "endpoints": [
        "https://github.com/xxww0098/SkillStar/releases/latest/download/latest.json"
      ]
    }
  }
}
